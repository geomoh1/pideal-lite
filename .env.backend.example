# Node/Express backend environment.
PORT=4000
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"
PI_API_BASE_URL=https://api.minepi.com/v2
PI_NETWORK_API_KEY=
PI_API_KEY=
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_ORIGINS=
PI_ADMIN_USERNAMES=mohammedabobaker
