# React/Vite frontend environment.
# Local development can leave this empty because vite.config.js proxies /api to the local backend.
VITE_API_BASE_URL=
VITE_PUBLIC_SITE_URL=
VITE_ENABLE_PI_SDK=false

# Production example:
# VITE_API_BASE_URL=https://your-pideal-backend.onrender.com
# VITE_PUBLIC_SITE_URL=https://your-public-pideal-domain.com
#
# Keep VITE_ENABLE_PI_SDK=false for normal browser demo testing.
# Set VITE_ENABLE_PI_SDK=true only if Pi App Studio instructions require forcing SDK usage
# outside automatic Pi Browser detection.
